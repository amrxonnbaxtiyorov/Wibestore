# Wallet Top-Up Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
WEB_APP_URL=https://your-domain.com/wallet-app
BACKEND_URL=http://localhost:8001
REDIS_URL=redis://localhost:6379/3

# Admin Telegram user IDs (comma-separated) — for approve/reject access control
ADMIN_TELEGRAM_IDS=your-telegram-id-here

# Optional: group/channel chat ID for admin notifications (e.g. -100xxxxxxxxxx)
# If set, transaction alerts go here instead of to individual admins.
ADMIN_CHAT_ID=