# ===================================
# Wallet Top-Up Backend Configuration
# ===================================
# Copy this to .env and fill in values

# App
APP_NAME=Wallet Top-Up API
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8001

# Database (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wallet_topup_db

# Redis
REDIS_URL=redis://localhost:6379/3

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here
BOT_API_SECRET=
WEB_APP_URL=https://your-domain.com/wallet-app

# Rate limits
RATE_LIMIT_SUBMISSIONS=3
RATE_LIMIT_WINDOW_SECONDS=600

# Amount limits
MIN_AMOUNT_UZS=10000
MAX_AMOUNT_UZS=50000000
MIN_AMOUNT_USDT=1.0
MAX_AMOUNT_USDT=10000.0

# File upload
MAX_RECEIPT_SIZE_BYTES=10485760
UPLOAD_DIR_STR=uploads/receipts

# Admin Telegram IDs (comma-separated)
ADMIN_TELEGRAM_IDS=123456789,987654321

# initData validation expiry (seconds)
INIT_DATA_MAX_AGE_SECONDS=300

# CORS
CORS_ORIGINS=*
