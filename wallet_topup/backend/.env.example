# Wallet Top-Up Backend
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8001

# PostgreSQL (async)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wallet_topup_db

# Redis (rate limit + notify bot)
REDIS_URL=redis://localhost:6379/3

# Telegram Bot Token (for initData validation and admin API secret)
