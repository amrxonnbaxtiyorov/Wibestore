{
  "name": "wibestore",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Gaming Accounts Marketplace - React + Django",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ci": "node scripts/fix-unicode-quotes.js && npm run build",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "logo:transparent": "node scripts/logo-remove-checkered.js",
    "logo:dark": "node scripts/logo-dark-mode.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:backend": "cd wibestore_backend && python manage.py runserver",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\""
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@react-oauth/google": "^0.13.4",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  }
}
