# WibeStore Frontend - Environment variables (Railway / local)
# Copy to .env and fill values. All VITE_* are embedded at build time.

# ---------------------------------------------------------------------------
# LOCAL DEVELOPMENT: Backend bilan ishlash uchun
# VITE_API_BASE_URL ni bo'sh qoldiring — Vite proxy /api ni localhost:8000 ga yuboradi.
# Avval backend ni ishga tushiring: cd wibestore_backend && python manage.py runserver
# Keyin: npm run dev  (yoki ikkalasini birga: npm run dev:all)
# ---------------------------------------------------------------------------
# PRODUCTION: Backend manzilini kiriting
VITE_API_BASE_URL=
# Misol: https://your-backend.up.railway.app/api/v1

VITE_WS_BASE_URL=
# Misol: wss://your-backend.up.railway.app

# Optional
VITE_GOOGLE_CLIENT_ID=
VITE_TELEGRAM_BOT_USERNAME=wibestorebot
# Admin panel: staff users log in via main site (Telegram/Google); no frontend admin credentials.
VITE_APP_ENV=production

# Optional - EmailJS, Sentry
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_SENTRY_DSN=

# Docker/Railway: BACKEND_URL is runtime-only (nginx proxy)
# BACKEND_URL=https://your-backend.up.railway.app/
