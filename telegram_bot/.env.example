# Telegram Bot — Railway / production
# Ushbu faylni .env sifatida nusxalab, qiymatlarni to'ldiring.
# Railway: Service → Variables da shu o'zgaruvchilarni o'rnating.

# @BotFather dan olingan token (majburiy)
BOT_TOKEN=123456:ABC-DEF...

# Backend API to'liq manzili (slashsiz). Railway'da backend servisining URL.
# Masalan: https://wibestore-backend.up.railway.app
WEBSITE_URL=https://YOUR_BACKEND_RAILWAY_URL

# Backend dagi TELEGRAM_BOT_SECRET bilan AYNAN bir xil (majburiy)
BOT_SECRET_KEY=wibestore-telegram-bot-secret-2024

# Frontend ro'yxatdan o'tish sahifasi (bot xabarida chiqadigan link)
# Masalan: https://wibestore.uz/signup yoki https://your-frontend.up.railway.app/signup
REGISTER_URL=https://YOUR_FRONTEND_URL/signup
