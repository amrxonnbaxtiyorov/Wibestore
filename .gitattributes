# Normalize all text files to LF in repo
* text=auto eol=lf

# Explicitly enforce LF for files used in Linux containers
*.sh text eol=lf
Dockerfile text eol=lf
*.conf text eol=lf
*.template text eol=lf
*.toml text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files: never convert
*.png binary
*.webp binary
*.svg binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
