# Django — Railway Backend: SECRET_KEY majburiy (bo‘lmasa random kalit ishlatiladi, restartda sessiya yo‘qoladi)
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (local)
# Railway: use DATABASE_PUBLIC_URL from Railway Postgres, or set DATABASE_URL to same value
DATABASE_URL=postgresql://wibestore:wibestore_password@localhost:5432/wibestore_db

# Redis (local). Railway: REDIS_URL yoki Redis Reference → REDIS_PUBLIC_URI
REDIS_URL=redis://localhost:6379/0

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@wibestore.net

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=10080

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Payments
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret-key
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret-key
PAYNET_MERCHANT_ID=your-paynet-merchant-id
PAYNET_SECRET_KEY=your-paynet-secret-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# S3-compatible Storage (Cloudflare R2 / AWS S3 / DigitalOcean Spaces)
# Cloudflare R2: dash.cloudflare.com -> R2 -> bucket yarating, API token oling
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
AWS_STORAGE_BUCKET_NAME=wibestore-media
AWS_S3_REGION_NAME=auto
# Cloudflare R2 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# Public bucket domain (R2 Settings -> Public access -> r2.dev yoki custom domain)
AWS_S3_CUSTOM_DOMAIN=pub-xxx.r2.dev

# Sentry (production error monitoring)
SENTRY_DSN=https://your-sentry-dsn

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend URL (email linklar: verify, reset-password). Railway: frontend manzilingiz
FRONTEND_URL=https://wibestore.net

# Telegram bot token (from @BotFather) — xabar yuborish uchun kerak
BOT_TOKEN=your-bot-token-here
# Telegram bot secret — API auth uchun
TELEGRAM_BOT_SECRET=wibestore-telegram-bot-secret-2024

# Encryption key for sensitive data (REQUIRED in production). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-encryption-key

# Django Admin (create_superuser.py / entrypoint use these; set ADMIN_PASSWORD on Railway)
ADMIN_EMAIL=admin@wibestore.net
ADMIN_PASSWORD=WibeStore2026!

# Admin Telegram IDs (через запятую)
ADMIN_TELEGRAM_IDS=123456789,987654321

# Chat notification delay in seconds
CHAT_NOTIFICATION_DELAY_SECONDS=10

# Escrow auto-release timeout in hours
ESCROW_AUTO_RELEASE_HOURS=48

# Delivery reminder threshold in hours
DELIVERY_REMINDER_HOURS=2

# Savdo tasdiqlash timeout (soat, default: 24)
TRADE_CONFIRMATION_TIMEOUT_HOURS=24

# Pul yechish minimal miqdori (so'mda, default: 10000)
WITHDRAWAL_MIN_AMOUNT=10000

# Pul yechish ko'rib chiqish timeout (soat, default: 48)
WITHDRAWAL_REVIEW_TIMEOUT_HOURS=48

# Platforma komissiya stavkasi (default: 0.05 = 5%)
PLATFORM_COMMISSION_RATE=0.05

# Verifikatsiya maksimal kutish vaqti (soat, default: 168 = 7 kun)
VERIFICATION_MAX_HOLD_HOURS=168
