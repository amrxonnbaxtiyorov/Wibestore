# ===== BOT TOKEN =====
BOT_TOKEN=your_bot_token_here

# ===== ADMIN TELEGRAM IDs (comma-separated) =====
ADMIN_IDS=123456789,987654321

# ===== HUMO CARD DETAILS =====
HUMO_CARD_NUMBER=9860 0803 0123 4567
HUMO_CARD_HOLDER=Ism Familiya

# ===== VISA / MASTERCARD DETAILS =====
VISA_CARD_NUMBER=4169 7388 1234 5678
VISA_CARD_HOLDER=Ism Familiya

# ===== DATABASE =====
# SQLite (default, no extra setup)
DATABASE_URL=sqlite+aiosqlite:///./payments.db
# PostgreSQL (production recommended):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/payment_bot

# ===== FILE STORAGE =====
RECEIPTS_DIR=receipts

# ===== ANTI-SPAM (seconds between requests) =====
THROTTLE_RATE=1.5

# ===== SITE INTEGRATION (optional) =====
# If set, bot will call this API to top up user balance after approval
SITE_API_URL=https://your-site.com
SITE_API_KEY=your_site_api_secret_key

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
